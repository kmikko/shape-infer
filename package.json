{
  "name": "shape-infer",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@8.6.2",
  "description": "Infer a unified schema from JSON/JSONL records and emit TypeScript, Zod, or JSON Schema.",
  "author": "kmikko",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kmikko/shape-infer.git"
  },
  "homepage": "https://github.com/kmikko/shape-infer#readme",
  "bugs": {
    "url": "https://github.com/kmikko/shape-infer/issues"
  },
  "keywords": [
    "schema",
    "json-schema",
    "typescript",
    "zod",
    "codegen",
    "jsonl",
    "ndjson",
    "inference",
    "schema-inference"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./public-api": {
      "types": "./dist/public-api.d.ts",
      "import": "./dist/public-api.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "bin": {
    "shape-infer": "dist/cli.js"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "check:type": "tsc -p tsconfig.json",
    "check:lint": "eslint . --ext .ts",
    "check:pack": "npm pack --dry-run",
    "check:format": "prettier --check \"**/*.{ts,md}\"",
    "check:all": "pnpm check:format && pnpm run check:type && pnpm run check:lint && pnpm run api:check && pnpm run check:pack",
    "api:check": "pnpm run build && api-extractor run -c api-extractor.index.json && api-extractor run -c api-extractor.public-api.json",
    "api:update": "pnpm run build && api-extractor run --local -c api-extractor.index.json && api-extractor run --local -c api-extractor.public-api.json",
    "dev": "node src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:update": "vitest run -u",
    "test:coverage": "vitest run --coverage",
    "test:type": "vitest run --typecheck --typecheck.only",
    "test:smoke": "node scripts/smoke.ts",
    "test:cli": "pnpm run build && node dist/cli.js --help",
    "test:pack": "node scripts/pack-smoke.ts",
    "test:all": "pnpm run test && pnpm run test:type && pnpm run test:smoke && pnpm run test:cli && pnpm run test:pack",
    "fix:format": "prettier --write \"**/*.{ts,md}\""
  },
  "dependencies": {
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.57.6",
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^4.0.18",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.0.2",
    "fast-check": "^4.5.3",
    "globals": "^17.3.0",
    "jiti": "^2.6.1",
    "prettier": "3.8.1",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  }
}
