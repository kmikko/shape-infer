{
  "name": "schema-generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@8.6.2",
  "description": "Infer a unified schema from JSON/JSONL records and emit TypeScript, Zod, or JSON Schema.",
  "bin": {
    "schema-gen": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "dev": "node src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:update": "vitest run -u",
    "test:coverage": "vitest run --coverage",
    "test:type": "vitest run --typecheck --typecheck.only",
    "smoke": "node scripts/smoke.ts",
    "smoke:dist": "node dist/cli.js --help",
    "check": "pnpm run test && pnpm run test:type && pnpm run smoke",
    "verify": "pnpm run typecheck && pnpm run check && pnpm run build && pnpm run smoke:dist",
    "test:ci": "pnpm run verify"
  },
  "dependencies": {
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  }
}
