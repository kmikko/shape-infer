exports[`public api golden snapshots > matches zod output snapshot 1`] = `
"import { z } from "zod";

export const UserSchemaSchema = z.object({
  "email": z.union([z.string(), z.null()]).optional(),
  "flags": z.object({
    "valid": z.boolean().optional(),
    "verified": z.boolean().optional(),
  }).optional(),
  "id": z.union([z.string(), z.number().int()]),
  "meta": z.object({
    "extra": z.string().optional(),
    "last_seen": z.union([z.string(), z.null()]).optional(),
    "login_count": z.number().int().optional(),
    "preferences": z.object({
      "theme": z.string().optional(),
    }).optional(),
  }),
  "name": z.string().optional(),
  "roles": z.array(z.string()),
});

export type UserSchema = z.infer<typeof UserSchemaSchema>;
"
`;
