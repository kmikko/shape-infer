    "zod": "import { z } from "zod";

export const OpenLibraryWorks = z.object({
  "authors": z.array(z.object({
      "author": z.object({
        "key": z.string(),
      }),
      "type": z.union([z.object({
        "key": z.string(),
      }), z.string()]),
    })).optional(),
  "covers": z.array(z.int()).optional(),
  "created": z.object({
    "type": z.string(),
    "value": z.string(),
  }),
  "description": z.object({
    "type": z.string(),
    "value": z.string(),
  }).optional(),
  "dewey_number": z.array(z.string()).optional(),
  "first_publish_date": z.string().optional(),
  "key": z.string(),
  "last_modified": z.object({
    "type": z.string(),
    "value": z.string(),
  }),
  "latest_revision": z.union([z.literal(1), z.literal(2), z.literal(3), z.literal(4), z.literal(5), z.literal(6)]),
  "lc_classifications": z.array(z.string()).optional(),
  "revision": z.union([z.literal(1), z.literal(2), z.literal(3), z.literal(4), z.literal(5), z.literal(6)]),
  "subject_people": z.array(z.string()).optional(),
  "subject_places": z.array(z.string()).optional(),
  "subject_times": z.array(z.string()).optional(),
  "subjects": z.array(z.string()).optional(),
  "subtitle": z.string().optional(),
  "title": z.string(),
  "type": z.object({
    "key": z.string(),
  }),
});

export type OpenLibraryWorks = z.infer<typeof OpenLibraryWorks>;
