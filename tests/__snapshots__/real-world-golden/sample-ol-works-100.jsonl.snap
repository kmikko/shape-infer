    "typescript": "export type OpenLibraryWorks = {
  authors?: Array<{
      author: {
        key: string;
      };
      type: {
        key: string;
      } | string;
    }>;
  covers?: Array<number>;
  created: {
    type: string;
    value: string;
  };
  description?: {
    type: string;
    value: string;
  };
  dewey_number?: Array<string>;
  first_publish_date?: string;
  key: string;
  last_modified: {
    type: string;
    value: string;
  };
  latest_revision: number;
  lc_classifications?: Array<string>;
  revision: number;
  subject_people?: Array<string>;
  subject_places?: Array<string>;
  subject_times?: Array<string>;
  subjects?: Array<string>;
  subtitle?: string;
  title: string;
  type: {
    key: string;
  };
};
