    "typescript": "export type Pokedex = {
  pokemon: Array<{
      avg_spawns: number;
      candy: string;
      candy_count?: 12 | 25 | 50 | 100;
      egg: "10 km" | "2 km" | "5 km" | "Not in Eggs";
      height: string;
      id: number;
      img: string;
      multipliers: Array<number> | null;
      name: string;
      next_evolution?: Array<{
          name: string;
          num: string;
        }>;
      num: string;
      prev_evolution?: Array<{
          name: string;
          num: string;
        }>;
      spawn_chance: number;
      spawn_time: string;
      type: Array<"Bug" | "Electric" | "Fighting" | "Fire" | "Flying" | "Ghost" | "Grass" | "Ground" | "Ice" | "Normal" | "Poison" | "Psychic" | "Rock" | "Water">;
      weaknesses: Array<"Bug" | "Dark" | "Electric" | "Fairy" | "Fighting" | "Fire" | "Flying" | "Ghost" | "Grass" | "Ground" | "Ice" | "Poison" | "Psychic" | "Rock" | "Steel" | "Water">;
      weight: string;
    }>;
};
",
    "zod": "import { z } from "zod";

export const Pokedex = z.object({
  "pokemon": z.array(z.object({
      "avg_spawns": z.number(),
      "candy": z.string(),
      "candy_count": z.union([z.literal(12), z.literal(25), z.literal(50), z.literal(100)]).optional(),
      "egg": z.enum(["10 km", "2 km", "5 km", "Not in Eggs"]),
      "height": z.string(),
      "id": z.int(),
      "img": z.url(),
      "multipliers": z.union([z.array(z.number()), z.null()]),
      "name": z.string(),
      "next_evolution": z.array(z.object({
          "name": z.string(),
          "num": z.string(),
        })).optional(),
      "num": z.string(),
      "prev_evolution": z.array(z.object({
          "name": z.string(),
          "num": z.string(),
        })).optional(),
      "spawn_chance": z.number(),
      "spawn_time": z.string(),
      "type": z.array(z.enum(["Bug", "Electric", "Fighting", "Fire", "Flying", "Ghost", "Grass", "Ground", "Ice", "Normal", "Poison", "Psychic", "Rock", "Water"])),
      "weaknesses": z.array(z.enum(["Bug", "Dark", "Electric", "Fairy", "Fighting", "Fire", "Flying", "Ghost", "Grass", "Ground", "Ice", "Poison", "Psychic", "Rock", "Steel", "Water"])),
      "weight": z.string(),
    })),
});

export type Pokedex = z.infer<typeof Pokedex>;
",
