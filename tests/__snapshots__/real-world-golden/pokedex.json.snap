    "zod": "import { z } from "zod";

export const Pokedex = z.object({
  "pokemon": z.array(z.object({
      "avg_spawns": z.number(),
      "candy": z.string(),
      "candy_count": z.int().optional(),
      "egg": z.string(),
      "height": z.string(),
      "id": z.int(),
      "img": z.url(),
      "multipliers": z.array(z.number()).nullable(),
      "name": z.string(),
      "next_evolution": z.array(z.object({
          "name": z.string(),
          "num": z.string(),
        })).optional(),
      "num": z.string(),
      "prev_evolution": z.array(z.object({
          "name": z.string(),
          "num": z.string(),
        })).optional(),
      "spawn_chance": z.number(),
      "spawn_time": z.string(),
      "type": z.array(z.string()),
      "weaknesses": z.array(z.string()),
      "weight": z.string(),
    })),
});

export type Pokedex = z.infer<typeof Pokedex>;
