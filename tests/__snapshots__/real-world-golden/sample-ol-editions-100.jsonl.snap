    value: string;
  };
  dewey_decimal_class?: Array<string>;
  edition_name?: string;
  full_title?: string;
  genres?: Array<string>;
  ia_box_id?: Array<string>;
  identifiers?: {
    amazon?: Array<string>;
    better_world_books?: Array<string>;
    goodreads?: Array<string>;
    librarything?: Array<string>;
  };
  isbn_10?: Array<string>;
  isbn_13?: Array<string>;
  key: string;
  languages?: Array<{
      key: string;
    }>;
  last_modified: {
    type: string;
    value: string;
  };
