    "zod": "import { z } from "zod";

export const OpenLibraryEditions = z.object({
  "authors": z.array(z.object({
      "key": z.string(),
    })).optional(),
  "by_statement": z.string().optional(),
  "classifications": z.object({}).optional(),
  "contributions": z.array(z.string()).optional(),
  "copyright_date": z.string().optional(),
  "covers": z.array(z.number().int()).optional(),
  "created": z.object({
    "type": z.string(),
    "value": z.string(),
  }).optional(),
  "description": z.object({
    "type": z.string(),
    "value": z.string(),
  }).optional(),
  "dewey_decimal_class": z.array(z.string()).optional(),
  "edition_name": z.string().optional(),
  "full_title": z.string().optional(),
  "genres": z.array(z.string()).optional(),
  "ia_box_id": z.array(z.string()).optional(),
  "identifiers": z.object({
    "amazon": z.array(z.string()).optional(),
    "better_world_books": z.array(z.string()).optional(),
    "goodreads": z.array(z.string()).optional(),
    "librarything": z.array(z.string()).optional(),
  }).optional(),
  "isbn_10": z.array(z.string()).optional(),
  "isbn_13": z.array(z.string()).optional(),
  "key": z.string(),
  "languages": z.array(z.object({
      "key": z.string(),
    })).optional(),
  "last_modified": z.object({
    "type": z.string(),
    "value": z.string(),
  }),
  "latest_revision": z.number().int(),
  "lc_classifications": z.array(z.string()).optional(),
  "lccn": z.array(z.string()).optional(),
  "links": z.array(z.object({
      "title": z.string(),
      "url": z.string(),
    })).optional(),
  "local_id": z.array(z.string().url()).optional(),
  "notes": z.object({
    "type": z.string(),
    "value": z.string(),
  }).optional(),
  "number_of_pages": z.number().int().optional(),
  "ocaid": z.string().optional(),
  "oclc_number": z.array(z.string()).optional(),
  "oclc_numbers": z.array(z.string()).optional(),
  "openlibrary": z.string().optional(),
  "other_titles": z.array(z.string()).optional(),
  "pagination": z.string().optional(),
  "physical_dimensions": z.string().optional(),
  "physical_format": z.string().optional(),
  "publish_country": z.string().optional(),
  "publish_date": z.string().optional(),
  "publish_places": z.array(z.string()).optional(),
  "publishers": z.array(z.string()).optional(),
  "revision": z.number().int(),
  "series": z.array(z.string()).optional(),
  "source_records": z.array(z.string().url()).optional(),
  "subject_people": z.array(z.string()).optional(),
  "subject_place": z.array(z.string()).optional(),
  "subject_places": z.array(z.string()).optional(),
  "subject_time": z.array(z.string()).optional(),
  "subject_times": z.array(z.string()).optional(),
  "subjects": z.array(z.string()).optional(),
  "subtitle": z.string().optional(),
  "table_of_contents": z.array(z.object({
      "level": z.number().int().optional(),
      "title": z.string(),
      "type": z.object({
        "key": z.string(),
      }),
    })).optional(),
  "title": z.string(),
  "title_prefix": z.string().optional(),
  "type": z.object({
    "key": z.string(),
  }),
  "url": z.array(z.string()).optional(),
  "weight": z.string().optional(),
  "work_title": z.array(z.string()).optional(),
  "works": z.array(z.object({
      "key": z.string(),
    })).optional(),
});

export type OpenLibraryEditions = z.infer<typeof OpenLibraryEditions>;
