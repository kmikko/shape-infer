  lc_classifications?: Array<string>;
  lccn?: Array<string>;
  links?: Array<{
      title: string;
      url: string;
    }>;
  local_id?: Array<string>;
  notes?: {
    type: string;
    value: string;
  };
  number_of_pages?: number;
  ocaid?: string;
  oclc_number?: Array<string>;
