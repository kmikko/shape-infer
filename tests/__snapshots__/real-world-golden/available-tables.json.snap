    "zod": "import { z } from "zod";

export const AvailableTables = z.object({
  "days": z.record(z.string(), z.union([z.array(z.object({
        "slot": z.string(),
        "tables": z.array(z.object({
            "number": z.int(),
            "room": z.string(),
            "size": z.int(),
          })),
      })), z.string()])),
});

export type AvailableTables = z.infer<typeof AvailableTables>;
