};
",
  "typescriptStrict": "export type SnapshotType = {
  category: string;
  certification: string | null;
  id: string | number;
  launchedAt: string;
  price: number | null;
  tags: Array<string>;
};
",
  "zodLooseOptional": "import { z } from "zod";

export const SnapshotType = z.object({
  "category": z.string().optional(),
  "certification": z.string().nullable().optional(),
  "id": z.union([z.string(), z.number().int()]).optional(),
  "launchedAt": z.string().optional(),
  "price": z.number().nullable().optional(),
  "tags": z.array(z.string()).optional(),
});

export type SnapshotType = z.infer<typeof SnapshotType>;
",
  "zodStrict": "import { z } from "zod";

export const SnapshotType = z.object({
  "category": z.string(),
  "certification": z.union([z.string(), z.null()]),
  "id": z.union([z.string(), z.number().int()]),
  "launchedAt": z.string(),
  "price": z.union([z.number(), z.null()]),
  "tags": z.array(z.string()),
});

export type SnapshotType = z.infer<typeof SnapshotType>;
",
}
`;

