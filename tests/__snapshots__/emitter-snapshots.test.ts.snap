// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`emitter golden snapshots > catalog-mixed 1`] = `
{
  "jsonSchemaLooseOptional": "{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SnapshotType",
  "type": "object",
  "properties": {
    "category": {
      "type": "string"
    },
    "certification": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer"
        }
      ]
    },
    "launchedAt": {
      "type": "string",
      "format": "date-time"
    },
    "price": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}",
  "jsonSchemaStrict": "{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SnapshotType",
  "type": "object",
  "properties": {
    "category": {
      "type": "string",
      "enum": [
        "Beer",
        "Wine"
      ]
    },
    "certification": {
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "Fair for Life",
            "Fairtrade"
          ]
        },
        {
          "type": "null"
        }
      ]
    },
    "id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "integer",
          "enum": [
            1,
            2
          ]
        }
      ]
    },
    "launchedAt": {
      "type": "string",
      "format": "date-time",
      "enum": [
        "2024-01-02T12:00:00Z",
        "2024-01-03T12:00:00Z",
        "not-a-date"
      ]
    },
    "price": {
      "anyOf": [
        {
          "type": "number",
          "enum": [
            10.5,
            12
          ]
        },
        {
          "type": "null"
        }
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "europe",
          "local",
          "sale"
        ]
      }
    }
  },
  "required": [
    "category",
    "certification",
    "id",
    "launchedAt",
    "price",
    "tags"
  ]
}",
  "typescriptLooseOptional": "export type SnapshotType = {
  category?: string;
  certification?: string | null;
  id?: string | number;
  launchedAt?: string;
  price?: number | null;
  tags?: Array<string>;
};
",
  "typescriptStrict": "export type SnapshotType = {
  category: "Beer" | "Wine";
  certification: "Fair for Life" | "Fairtrade" | null;
  id: string | 1 | 2;
  launchedAt: "2024-01-02T12:00:00Z" | "2024-01-03T12:00:00Z" | "not-a-date";
  price: 10.5 | 12 | null;
  tags: Array<"europe" | "local" | "sale">;
};
",
  "zodLooseOptional": "import { z } from "zod";

export const SnapshotTypeSchema = z.object({
  "category": z.string().optional(),
  "certification": z.string().nullable().optional(),
  "id": z.union([z.string(), z.number().int()]).optional(),
  "launchedAt": z.string().datetime().optional(),
  "price": z.number().nullable().optional(),
  "tags": z.array(z.string()).optional(),
});

export type SnapshotType = z.infer<typeof SnapshotTypeSchema>;
",
  "zodStrict": "import { z } from "zod";

export const SnapshotTypeSchema = z.object({
  "category": z.enum(["Beer", "Wine"]),
  "certification": z.union([z.enum(["Fair for Life", "Fairtrade"]), z.null()]),
  "id": z.union([z.string(), z.union([z.literal(1), z.literal(2)])]),
  "launchedAt": z.enum(["2024-01-02T12:00:00Z", "2024-01-03T12:00:00Z", "not-a-date"]),
  "price": z.union([z.union([z.literal(10.5), z.literal(12)]), z.null()]),
  "tags": z.array(z.enum(["europe", "local", "sale"])),
});

export type SnapshotType = z.infer<typeof SnapshotTypeSchema>;
",
}
`;

exports[`emitter golden snapshots > record-like-attributes 1`] = `
{
  "jsonSchemaLooseOptional": "{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SnapshotType",
  "type": "object",
  "properties": {
    "attributes": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ]
      }
    },
    "sku": {
      "type": "string"
    }
  }
}",
  "jsonSchemaStrict": "{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SnapshotType",
  "type": "object",
  "properties": {
    "attributes": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string",
            "enum": [
              "aged",
              "dry",
              "fresh",
              "no",
              "red",
              "sparkling",
              "sweet",
              "white",
              "yes",
              "young"
            ]
          },
          {
            "type": "null"
          }
        ]
      }
    },
    "sku": {
      "type": "string",
      "enum": [
        "A-1",
        "A-2",
        "A-3"
      ]
    }
  },
  "required": [
    "attributes",
    "sku"
  ]
}",
  "typescriptLooseOptional": "export type SnapshotType = {
  attributes?: Record<string, string | null>;
  sku?: string;
};
",
  "typescriptStrict": "export type SnapshotType = {
  attributes: Record<string, "aged" | "dry" | "fresh" | "no" | "red" | "sparkling" | "sweet" | "white" | "yes" | "young" | null>;
  sku: "A-1" | "A-2" | "A-3";
};
",
  "zodLooseOptional": "import { z } from "zod";

export const SnapshotTypeSchema = z.object({
  "attributes": z.record(z.string(), z.string().nullable()).optional(),
  "sku": z.string().optional(),
});

export type SnapshotType = z.infer<typeof SnapshotTypeSchema>;
",
  "zodStrict": "import { z } from "zod";

export const SnapshotTypeSchema = z.object({
  "attributes": z.record(z.string(), z.union([z.enum(["aged", "dry", "fresh", "no", "red", "sparkling", "sweet", "white", "yes", "young"]), z.null()])),
  "sku": z.enum(["A-1", "A-2", "A-3"]),
});

export type SnapshotType = z.infer<typeof SnapshotTypeSchema>;
",
}
`;
